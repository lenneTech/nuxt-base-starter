{
  "name": "nuxt-base-template",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "node": "./tslib.es6.mjs"
      }
    }
  },
  "scripts": {
    "c": "pnpm run check",
    "check": "pnpm audit && pnpm run format:check && pnpm run lint && pnpm test && pnpm run build && bash scripts/check-server-start.sh",
    "check:fix": "pnpm install && pnpm audit --fix && pnpm run format && pnpm run lint:fix && pnpm test && pnpm run build && bash scripts/check-server-start.sh",
    "check:naf": "pnpm install && pnpm run format && pnpm run lint:fix && pnpm test && pnpm run build && bash scripts/check-server-start.sh",
    "cf": "pnpm run check:fix",
    "cnaf": "pnpm run check:naf",
    "init": "pnpm install",
    "reinit": "npx rimraf pnpm-lock.yaml && npx nuxt cleanup && npx rimraf node_modules && pnpm install",
    "clean": "npx rimraf .nuxt .output",
    "dev": "nuxt dev",
    "build": "nuxt build",
    "build:develop": "npx cross-env NODE_ENV=development nuxt build",
    "build:test": "npx cross-env NODE_ENV=test nuxt build",
    "build:prod": "npx cross-env NODE_ENV=production nuxt build",
    "start": "nuxt dev",
    "start:develop": "node .output/server/index.mjs",
    "start:test": "node .output/server/index.mjs",
    "start:prod": "node .output/server/index.mjs",
    "start:tunnel": "nuxt dev --tunnel",
    "start:extern": "npx cross-env HOST=0.0.0.0 nuxt dev",
    "generate": "nuxt generate",
    "generate-types": "openapi-ts",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "simple-git-hooks",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:all": "pnpm run test:unit && pnpm run test:e2e",
    "lint": "oxlint app/",
    "lint:fix": "oxlint --fix --fix-suggestions app/",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "fix": "pnpm run lint:fix && pnpm run format"
  },
  "dependencies": {
    "@better-auth/passkey": "1.6.9",
    "@lenne.tech/bug.lt": "latest",
    "@lenne.tech/nuxt-extensions": "1.5.4",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "4.7.0",
    "@pinia/nuxt": "0.11.3",
    "@vueuse/nuxt": "14.2.1",
    "better-auth": "1.6.9",
    "qrcode": "1.5.4",
    "tus-js-client": "4.3.1",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.97.0",
    "@iconify-json/lucide": "1.2.104",
    "@nuxt/devtools": "3.2.4",
    "@nuxt/test-utils": "4.0.3",
    "@nuxtjs/plausible": "3.0.2",
    "@nuxtjs/seo": "5.1.3",
    "@playwright/test": "1.59.1",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "25.6.0",
    "@types/qrcode": "1.5.6",
    "@unhead/bundler": "3.0.4",
    "@vitejs/plugin-vue": "6.0.6",
    "@vue/test-utils": "2.4.9",
    "dayjs-nuxt": "2.1.11",
    "happy-dom": "20.9.0",
    "lint-staged": "16.4.0",
    "mongodb": "7.2.0",
    "nuxt": "4.4.2",
    "oxfmt": "latest",
    "oxlint": "latest",
    "rimraf": "6.1.3",
    "simple-git-hooks": "2.13.1",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "pnpm run test:unit"
  },
  "lint-staged": {
    "app/**/*.{ts,vue}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "tests/**/*.ts": [
      "oxlint --fix"
    ]
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "pnpm": {
    "ignoredOptionalDependencies": [
      "@img/sharp-linux-arm",
      "@img/sharp-linux-arm64",
      "@img/sharp-linux-ppc64",
      "@img/sharp-linux-riscv64",
      "@img/sharp-linux-s390x",
      "@img/sharp-linux-x64",
      "@img/sharp-linuxmusl-arm64",
      "@img/sharp-linuxmusl-x64",
      "@img/sharp-win32-arm64",
      "@img/sharp-win32-ia32",
      "@img/sharp-win32-x64",
      "@img/sharp-wasm32",
      "@img/sharp-libvips-linux-arm",
      "@img/sharp-libvips-linux-arm64",
      "@img/sharp-libvips-linux-ppc64",
      "@img/sharp-libvips-linux-riscv64",
      "@img/sharp-libvips-linux-s390x",
      "@img/sharp-libvips-linux-x64",
      "@img/sharp-libvips-linuxmusl-arm64",
      "@img/sharp-libvips-linuxmusl-x64",
      "@resvg/resvg-js-android-arm-eabi",
      "@resvg/resvg-js-android-arm64",
      "@resvg/resvg-js-linux-arm-gnueabihf",
      "@resvg/resvg-js-linux-arm64-gnu",
      "@resvg/resvg-js-linux-arm64-musl",
      "@resvg/resvg-js-linux-x64-gnu",
      "@resvg/resvg-js-linux-x64-musl",
      "@resvg/resvg-js-win32-arm64-msvc",
      "@resvg/resvg-js-win32-ia32-msvc",
      "@resvg/resvg-js-win32-x64-msvc"
    ],
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp",
      "simple-git-hooks",
      "vue-demi"
    ],
    "overrides": {
      "@hono/node-server@<1.19.14": "1.19.14",
      "brace-expansion@>=2.0.0 <2.0.3": "2.1.0",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5",
      "drizzle-orm@<0.45.2": "0.45.2",
      "readdir-glob@<2.0.3": "3.0.0",
      "defu@<=6.1.4": "6.1.7",
      "devalue@<=5.6.3": "5.7.1",
      "effect@<3.20.0": "3.21.2",
      "fast-xml-parser@<5.7.0": "5.7.2",
      "h3@<1.15.9": "1.15.11",
      "h3@>=2.0.0-0 <2.0.1-rc.18": "2.0.1-rc.20",
      "h3-next": "npm:h3@2.0.1-rc.20",
      "hono@<4.12.14": "4.12.15",
      "kysely@>=0.26.0 <=0.28.13": "0.28.16",
      "lodash@>=4.0.0 <=4.17.23": "4.18.1",
      "minimatch@>=9.0.0 <9.0.7": "9.0.9",
      "node-forge@<1.4.0": "1.4.0",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "rollup@>=4.0.0 <4.59.0": "4.60.2",
      "serialize-javascript@<=7.0.4": "7.0.5",
      "srvx@<0.11.13": "0.11.15",
      "tar@<=7.5.10": "7.5.13",
      "unhead@<=2.1.12": "2.1.13",
      "vite@>=7.0.0 <7.3.2": "7.3.2",
      "yaml@>=2.0.0 <2.8.3": "2.8.3",
      "postcss@<8.5.10": "8.5.12"
    }
  }
}
